#pragma once

// Copy this file to config.h and fill in your values.
// config.h is gitignored — never commit credentials.

// Wi-Fi — default credentials (overridable from Settings menu -> Wi-Fi -> Serial or Manual)
#define WIFI_SSID_DEFAULT   "YourNetworkName"
#define WIFI_PASS_DEFAULT   "YourPassword"

// DCS-BIOS network
#define DCSBIOS_MCAST_ADDR  "239.255.50.10"
#define DCSBIOS_MCAST_PORT  5010
#define DCSBIOS_CMD_PORT    7778

// Device identity
#define FIRMWARE_VERSION     "0.20"
#define FIRMWARE_VERSION_BCD  0x001A  // BCD: 0xMMmm — keep in sync with FIRMWARE_VERSION
#define DEVICE_NAME         "Brew370"

// OTA updates
#define OTA_MANIFEST_URL    "https://raw.githubusercontent.com/YOUR_GITHUB_USER/Brew370/main/ota/manifest.json"
